{
  "name": "telegram-bot-boilerplate",
  "version": "1.0.0",
  "description": "Standard TypeScript boilerplate for Telegram bots using Hono, grammY, and Drizzle ORM.",
  "type": "module",
  "main": "dist/src/index.js",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/src/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "webhook:set": "tsx scripts/manage-webhook.ts set",
    "webhook:delete": "tsx scripts/manage-webhook.ts delete",
    "webhook:info": "tsx scripts/manage-webhook.ts info",
    "lint": "biome check src scripts tests drizzle.config.ts",
    "lint:write": "biome check --write src scripts tests drizzle.config.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "grammy": "^1.44.0",
    "hono": "^4.12.27",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
