{
  "name": "telegram-bot-boilerplate",
  "version": "1.0.0",
  "description": "Standard TypeScript boilerplate for Telegram bots using Hono, grammY, and Drizzle ORM.",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/src/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "biome check src",
    "lint:write": "biome check --write src",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.17.1",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.0.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.3",
    "grammy": "^1.36.3",
    "hono": "^4.8.5",
    "qrcode": "^1.5.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.16.0",
    "@types/qrcode": "^1.5.5",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
