# Startup mode: polling | webhook | http-only
BOT_MODE=webhook

# Telegram credentials
TELEGRAM_BOT_TOKEN=123456789:abcdefghijklmnopqrstuvwxyz
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Webhook configuration (required when BOT_MODE=webhook)
# TELEGRAM_WEBHOOK_SECRET must be at least 32 characters
TELEGRAM_WEBHOOK_SECRET=some_random_secret_token_at_least_32_chars_long
PUBLIC_WEBHOOK_URL=https://mybot.domain.com

# Server network settings
PORT=8080
# Use 0.0.0.0 for Docker/Container deployments
BIND_HOST=0.0.0.0

# Database file location
DATABASE_URL=./data/bot.db
